Algoritmo Lecc30_Act1_Inc2
	Definir num Como Entero
    Definir dinero Como Caracter
    Dimension dinero[5]
    
    dinero[1] <- "Q100"
    dinero[2] <- "Q300"
	dinero[3] <- "Q50"
	dinero[4] <- "Q1,000"
	dinero[5] <- "Q35,000"
    
    Escribir "Ingrese un número del 1 al 5: "
    Leer num
    
    Escribir dinero[num]
FinAlgoritmo
